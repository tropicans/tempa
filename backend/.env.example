# Backend Environment Variables
# Copy this file to .env and fill in the values

# PostgreSQL connection string
# Local:  postgresql://postgres:postgres@localhost:7432/tempa?schema=public
# Docker: postgresql://postgres:postgres@postgres:5432/tempa?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:7432/tempa?schema=public"

# JWT secret for signing auth tokens (CHANGE THIS IN PRODUCTION)
JWT_SECRET=tempa-dev-secret-change-in-production

# Default tenant / program seeding
DEFAULT_TENANT_CODE=tempa-demo
DEFAULT_TENANT_NAME="TEMPA Demo Tenant"
DEFAULT_PROGRAM_CODE=tempa-program
DEFAULT_PROGRAM_NAME="TEMPA Leadership Program"
DEFAULT_COHORT_CODE=cohort-2026
DEFAULT_COHORT_NAME="Cohort 2026"
DEFAULT_MENTOR_ALIAS=mentor-demo

# OpenAI (optional, for AI-assist features)
# OPENAI_API_KEY=sk-...
